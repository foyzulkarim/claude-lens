# Path to your Claude data directory (defaults to ~/.claude if not set)
CLAUDE_DIR=/Users/yourname/.claude

# Pricing in USD per million tokens (defaults match Bedrock cross-region ap-southeast-2)
# Anthropic API rates: RATE_INPUT=15, RATE_OUTPUT=75, RATE_CACHE_READ=1.5, RATE_CACHE_CREATE=18.75
RATE_INPUT=5.0
RATE_OUTPUT=25.0
RATE_CACHE_READ=0.5
RATE_CACHE_CREATE=6.25
